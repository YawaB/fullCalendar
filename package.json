{
  "name": "easycal-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20 <23",
    "pnpm": ">=9"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "node ./scripts/check-node.js",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @brinda_yawa/easycal build",
    "build:react": "pnpm --filter @brinda_yawa/easycal-react build",
    "demo": "node server.js"
  }
}
